# This is Git's per-user configuration file.
[user]
	name = Christina Phan
	email = 88528865+christinaphan@users.noreply.github.com
[init]
	defaultBranch = main
[color]
  diff = auto
  status = auto
[color "branch"]
  current = cyan
  local = green
  remote = red
[color "diff"]
  meta = yellow
  frag = magenta
  old = red
  new = green
[color "status"]
  added = cyan
  branch = cyan
  changed = magenta
  deleted = red
  untracked = yellow
[core]
	editor = /usr/bin/nvim
[diff]
	tool = nvim -d
[merge]
	tool = nvim -d
